@page "/error"

<PageTitle>Error</PageTitle>

<MudStack Spacing="3" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Large" />
        <MudText Typo="Typo.h3">Something went wrong</MudText>
    </MudStack>

    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
        An unhandled error occurred while processing your request. Try the action again, or return to the home page.
    </MudAlert>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Return home</MudButton>
    </MudStack>
</MudStack>
